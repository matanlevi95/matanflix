# Copy to .env and fill in. The app runs without keys (empty results + warnings).

# TMDB — https://www.themoviedb.org/settings/api  (v3 key OR v4 bearer token)
TMDB_API_KEY=

# YouTube Data API v3 — https://console.cloud.google.com/apis
YOUTUBE_API_KEY=

# OpenSubtitles REST — https://www.opensubtitles.com/en/consumers
OPENSUBTITLES_API_KEY=
OPENSUBTITLES_USER_AGENT=Matanflix v1.0

# Stremio addons (comma-separated base/manifest URLs). Default = official
# Cinemeta (legal catalog search). Add stream-capable addon URLs to get
# playable streams, e.g.:
#   STREMIO_ADDONS=https://v3-cinemeta.strem.io,https://my-stream-addon/manifest.json
STREMIO_ADDONS=https://v3-cinemeta.strem.io

# Cache TTL for TMDB metadata (hours)
METADATA_CACHE_TTL_HOURS=24

# SQLite file
DATABASE_PATH=mytv.db

HOST=0.0.0.0
PORT=8000
